set shell := ["bash", "-euo", "pipefail", "-c"]

# default: List available recipes.
default:
  @just --list


# bootstrap: Install Homebrew and the minimum required bootstrap dependencies.
bootstrap:
  #!/usr/bin/env bash
  if ! command -v brew >/dev/null 2>&1; then
    echo "[bootstrap] brew: installing" >&2
    bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if [[ -x /opt/homebrew/bin/brew ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x /usr/local/bin/brew ]]; then
      eval "$(/usr/local/bin/brew shellenv)"
    fi
  fi

  command -v brew >/dev/null 2>&1 || {
    echo "[bootstrap] brew: installed but not on PATH" >&2
    exit 1
  }

  if ! command -v chezmoi >/dev/null 2>&1; then
    echo "[bootstrap] chezmoi: installing" >&2
    brew install chezmoi
  fi

# update: Pull updates for components without changing the current environment.
update:
  #!/usr/bin/env bash
  if command -v chezmoi >/dev/null 2>&1; then
    echo "[update] chezmoi: git fetch --all --prune" >&2
    chezmoi git -- fetch --all --prune
  fi

  if command -v brew >/dev/null 2>&1; then
    echo "[update] brew: update" >&2
    brew update
  fi

  if command -v mise >/dev/null 2>&1; then
    echo "[update] mise: plugins update" >&2
    mise plugins update || true
  fi

# apply: Apply pulled updates to the current environment without deleting dependencies.
apply:
  #!/usr/bin/env bash
  branch="${BRANCH:-main}"
  excludes=",${EXCLUDES:-},"
  bundle_file="${HOMEBREW_BUNDLE_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/Brewfile}"
  tpm_root="${TMUX_PLUGIN_MANAGER_PATH:-${XDG_DATA_HOME:-$HOME/.local/share}/tmux/plugins}"

  if command -v chezmoi >/dev/null 2>&1 && [[ "$excludes" != *",chezmoi,"* ]]; then
    current="$(chezmoi git -- rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
    if [[ "$current" != "$branch" ]]; then
      echo "[apply] chezmoi: git checkout $branch" >&2
      chezmoi git -- checkout "$branch" || true
    fi

    file=""
    while IFS= read -r -d '' file; do
      [[ -n "$file" ]] || continue
      [[ -r "$file" ]] || continue
      chezmoi diff --no-pager -- "$file" | grep -q . || continue
      mkdir -p "$(dirname "$file")"
      echo "[apply] chezmoi: $file" >&2
      chezmoi apply --force -- "$file"
    done < <(chezmoi managed --include=files,symlinks --nul-path-separator -p absolute)
  fi

  if command -v brew >/dev/null 2>&1 && [[ "$excludes" != *",brew,"* ]]; then
    echo "[apply] brew: upgrade" >&2
    brew upgrade || true
    echo "[apply] brew: upgrade --cask" >&2
    brew upgrade --cask || true
    if [[ -f "$bundle_file" ]]; then
      echo "[apply] brew: bundle --file $bundle_file" >&2
      brew bundle --file "$bundle_file"
    fi
  fi

  if command -v mas >/dev/null 2>&1 && [[ "$excludes" != *",mas,"* ]]; then
    echo "[apply] mas: upgrade" >&2
    mas upgrade || true
  fi

  if command -v mise >/dev/null 2>&1 && [[ "$excludes" != *",mise,"* ]]; then
    echo "[apply] mise: install" >&2
    mise install
    echo "[apply] mise: upgrade" >&2
    mise upgrade
  fi

  if command -v sheldon >/dev/null 2>&1 && [[ "$excludes" != *",sheldon,"* ]]; then
    echo "[apply] sheldon: lock --update" >&2
    sheldon lock --update
  fi

  if [[ "$excludes" != *",tpm,"* ]]; then
    install_plugins="$tpm_root/bin/install_plugins"
    update_plugins="$tpm_root/bin/update_plugins"

    if [[ -x "$install_plugins" ]]; then
      echo "[apply] tpm: install plugins" >&2
      "$install_plugins" || true
    fi

    if [[ -x "$update_plugins" ]]; then
      echo "[apply] tpm: update plugins" >&2
      "$update_plugins" all || true
    fi
  fi

  if command -v nvim >/dev/null 2>&1 && [[ "$excludes" != *",nvim,"* ]]; then
    echo '[apply] nvim: headless "+Lazy! sync" "+qa"' >&2
    nvim --headless "+Lazy! sync" "+qa"
  fi

# prune: Remove unused dependencies from the current environment after updates are pulled.
prune:
  #!/usr/bin/env bash
  excludes=",${EXCLUDES:-},"
  tpm_root="${TMUX_PLUGIN_MANAGER_PATH:-${XDG_DATA_HOME:-$HOME/.local/share}/tmux/plugins}"

  if command -v brew >/dev/null 2>&1 && [[ "$excludes" != *",brew,"* ]]; then
    echo "[prune] brew: autoremove" >&2
    brew autoremove
    echo "[prune] brew: cleanup" >&2
    brew cleanup
  fi

  if command -v mise >/dev/null 2>&1 && [[ "$excludes" != *",mise,"* ]]; then
    echo "[prune] mise: prune" >&2
    mise prune -y
  fi

  if [[ "$excludes" != *",tpm,"* ]]; then
    clean_plugins="$tpm_root/bin/clean_plugins"
    if [[ -x "$clean_plugins" ]]; then
      echo "[prune] tpm: clean plugins" >&2
      "$clean_plugins"
    fi
  fi

# commit: Save the current environment state into the local chezmoi state.
commit:
  #!/usr/bin/env bash
  excludes=",${EXCLUDES:-},"
  bundle_file="${HOMEBREW_BUNDLE_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/Brewfile}"
  verbose="${VERBOSE:-0}"
  comment_fmt="${COMMENT:-source %s sync %d files}"

  command -v chezmoi >/dev/null 2>&1 || {
    echo "[commit] chezmoi: missing" >&2
    exit 1
  }

  if command -v brew >/dev/null 2>&1 && [[ "$excludes" != *",brew,"* ]]; then
    echo "[commit] brew: bundle dump $bundle_file" >&2
    if ((verbose)); then
      brew bundle dump --file "$bundle_file" --tap --formula --cask --services --no-restart --force --verbose
    else
      brew bundle dump --file "$bundle_file" --tap --formula --cask --services --no-restart --force
    fi
  fi

  file=""
  while IFS= read -r -d '' file; do
    [[ -n "$file" ]] || continue
    [[ -r "$file" ]] || continue
    chezmoi diff --no-pager -- "$file" | grep -q . || continue
    echo "[commit] chezmoi: add $file" >&2
    chezmoi add --no-pager --force "$file"
  done < <(chezmoi managed --include=files,symlinks --nul-path-separator -p absolute)

  if [[ -z "$(chezmoi git -- status --porcelain=v1)" ]]; then
    exit 0
  fi

  count="$(chezmoi git -- status --porcelain=v1 | wc -l | awk '{print $1}')"
  user="${USER:-unknown}"
  host="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo unknown)"

  if command -v md5sum >/dev/null 2>&1; then
    hash="$(printf "%s" "${user}@${host}" | md5sum | awk '{print $1}')"
  else
    hash="$(printf "%s" "${user}@${host}" | md5 -q)"
  fi

  printf -v message "$comment_fmt" "$hash" "$count"
  echo "[commit] chezmoi: $message" >&2
  chezmoi git -- add -A
  chezmoi git -- commit -m "$message"

# push: Push the local chezmoi state to the remote repository.
push:
  #!/usr/bin/env bash
  command -v chezmoi >/dev/null 2>&1 || exit 0

  repo="$(chezmoi git -- config --get remote.origin.url 2>/dev/null || echo unknown)"
  ahead="$(chezmoi git -- rev-list --count @{u}..HEAD 2>/dev/null || echo 0)"

  if [[ "$ahead" == "0" ]]; then
    echo "[push] chezmoi: no changes to push" >&2
    exit 0
  fi

  echo "[push] chezmoi: push to ${repo}" >&2
  chezmoi git -- push

# color256: Render 256 colortest in the terminal.
color256:
  #!/usr/bin/env bash
  fill() {
    printf "$(tput setaf "$1")%3d$(tput setab "$1") $(tput sgr0)" "$1"
  }
  for i in {0..15}; do fill "$i"; done
  printf "\n"
  for i in {232..255}; do fill "$i"; done
  printf "\n"
  for i in {16..231}; do
    fill "$i"
    if ((i % 36 == 15)); then printf "\n"; fi
  done

# color16: Render 16 colortest in the terminal.
color16:
  #!/usr/bin/env bash
  fill() {
    printf "$(tput sgr0)$(tput setaf "$1")%14s %2d$(tput setaf 15)$(tput setab "$1") * $(tput sgr0)" "$2" "$1"
    printf "$(tput setaf 0)$(tput setab $(($1 + 8))) * $(tput sgr0)$(tput setaf $(($1 + 8)))%-3d%-s$(tput sgr0)" "$(($1 + 8))" "BRIGHT $2"
    printf "\n"
  }
  fill 0 "BLACK"
  fill 1 "RED"
  fill 2 "GREEN"
  fill 3 "YELLOW"
  fill 4 "BLUE"
  fill 5 "PURPLE/MAGENTA"
  fill 6 "CYAN"
  fill 7 "WHITE"

# ansi: Render ANSI colortest in the terminal.
ansi:
  #!/usr/bin/env bash
  for b in 0 {30..37}; do
    for a in 0 1; do
      for c in {0..9} {40..47}; do
        printf " \e[${a};${b};${c}m%11s\e[0m" "\e[${a};${b};${c}m"
      done
      printf "\n"
    done
  done

# rainbow: Render Rainbow colortest in the terminal.
rainbow:
  #!/usr/bin/env bash
  for i in {0..127}; do
    h=$((i / 43))
    t=$(((i - 43 * h) * 255 / 43))
    q=$((255 - t))
    case $h in
      0) printf "\e[48:2:%d:%d:%dm \e[0m" 255 "$t" 0 ;;
      1) printf "\e[48:2:%d:%d:%dm \e[0m" "$q" 255 0 ;;
      2) printf "\e[48:2:%d:%d:%dm \e[0m" 0 255 "$t" ;;
      3) printf "\e[48:2:%d:%d:%dm \e[0m" 0 "$q" 255 ;;
      4) printf "\e[48:2:%d:%d:%dm \e[0m" "$t" 0 255 ;;
      5) printf "\e[48:2:%d:%d:%dm \e[0m" 255 0 "$q" ;;
      *) printf "\e[48:2:%d:%d:%dm \e[0m" 0 0 0 ;;
    esac
  done
  printf "\n"
  for i in {255..128}; do
    h=$((i / 43))
    t=$(((i - 43 * h) * 255 / 43))
    q=$((255 - t))
    case $h in
      0) printf "\e[48:2:%d:%d:%dm \e[0m" 255 "$t" 0 ;;
      1) printf "\e[48:2:%d:%d:%dm \e[0m" "$q" 255 0 ;;
      2) printf "\e[48:2:%d:%d:%dm \e[0m" 0 255 "$t" ;;
      3) printf "\e[48:2:%d:%d:%dm \e[0m" 0 "$q" 255 ;;
      4) printf "\e[48:2:%d:%d:%dm \e[0m" "$t" 0 255 ;;
      5) printf "\e[48:2:%d:%d:%dm \e[0m" 255 0 "$q" ;;
      *) printf "\e[48:2:%d:%d:%dm \e[0m" 0 0 0 ;;
    esac
  done
  printf "\n"
  for i in {0..127}; do printf "\e[48:2:%d:%d:%dm \e[0m" "$i" 0 0; done
  printf "\n"
  for i in {255..128}; do printf "\e[48:2:%d:%d:%dm \e[0m" "$i" 0 0; done
  printf "\n"
  for i in {0..127}; do printf "\e[48:2:%d:%d:%dm \e[0m" 0 "$i" 0; done
  printf "\n"
  for i in {255..128}; do printf "\e[48:2:%d:%d:%dm \e[0m" 0 "$i" 0; done
  printf "\n"
  for i in {0..127}; do printf "\e[48:2:%d:%d:%dm \e[0m" 0 0 "$i"; done
  printf "\n"
  for i in {255..128}; do printf "\e[48:2:%d:%d:%dm \e[0m" 0 0 "$i"; done
  printf "\n"
