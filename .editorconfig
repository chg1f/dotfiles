# encoding=utf-8
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
tab_width = 4
indent_size = 2
indent_style = space

[*.sql]
indent_size = 2
indent_style = space

[*.py]
indent_size = 4
indent_style = space

[*.{js,jsx,ts,tsx}]
indent_size = 4
indent_style = space

[*.go]
indent_size = 4
indent_style = tab

[Makefile]
indent_style = tab
